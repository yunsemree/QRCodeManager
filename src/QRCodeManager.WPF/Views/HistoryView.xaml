<UserControl x:Class="QRCodeManager.WPF.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:QRCodeManager.WPF.Converters">
    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter" />
        <converters:QrTypeToDisplayConverter x:Key="QrTypeToDisplayConverter" />
        <converters:HistoryIndexToAccentConverter x:Key="HistoryIndexToAccentConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="Yenile"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding RefreshCommand}" />
            <Button Content="Aç"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding OpenSelectedCommand}" />
            <Button Content="Yeniden Oluştur"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding RegenerateSelectedCommand}" />
            <Button Content="Sil"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding DeleteSelectedCommand}" />
        </WrapPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListBox ItemsSource="{Binding HistoryItems}"
                     SelectedItem="{Binding SelectedItem}"
                     BorderThickness="0"
                     Background="Transparent"
                     AlternationCount="4"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DashboardCard}"
                                Padding="0"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        CornerRadius="12,0,0,12"
                                        Background="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource HistoryIndexToAccentConverter}}" />

                                <StackPanel Grid.Column="1" Margin="20,16,12,16">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TitleTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <materialDesign:PackIcon Kind="Tag" Width="16" Height="16"
                                                                 Foreground="{DynamicResource MutedTextBrush}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding QrType, Converter={StaticResource QrTypeToDisplayConverter}}"
                                                   Margin="6,0,16,0"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16"
                                                                 Foreground="{DynamicResource MutedTextBrush}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CreatedDate, StringFormat=dd.MM.yyyy HH:mm}"
                                                   Margin="6,0,0,0"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Width="72" Height="72"
                                        Margin="0,0,20,0"
                                        Background="{DynamicResource PreviewPanelBrush}"
                                        CornerRadius="10"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding PreviewImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                           Width="56" Height="56"
                                           Stretch="Uniform" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MutedTextBrush}" />
    </Grid>
</UserControl>
