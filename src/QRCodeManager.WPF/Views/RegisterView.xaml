<UserControl x:Class="QRCodeManager.WPF.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Border Style="{StaticResource DashboardCard}"
                MaxWidth="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="28">
            <StackPanel>
                <TextBlock Text="Kayıt Ol"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}" />
                <TextBlock Text="Yeni hesap oluşturun veya giriş yapmadan devam edin."
                           Margin="0,8,0,24"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" />

                <TextBox Margin="0,0,0,16"
                         materialDesign:HintAssist.Hint="Ad Soyad"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox Margin="0,0,0,16"
                         materialDesign:HintAssist.Hint="E-posta"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <PasswordBox x:Name="PasswordBox"
                             Margin="0,0,0,16"
                             materialDesign:HintAssist.Hint="Şifre"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             PasswordChanged="OnPasswordChanged" />

                <PasswordBox x:Name="ConfirmPasswordBox"
                             Margin="0,0,0,20"
                             materialDesign:HintAssist.Hint="Şifre Tekrar"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             PasswordChanged="OnConfirmPasswordChanged" />

                <Button Content="Kayıt Ol"
                        Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding RegisterCommand}" />

                <Button Content="Giriş Yap"
                        Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding GoToLoginCommand}" />

                <Button Content="Atla ve Devam Et"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding SkipCommand}" />

                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
