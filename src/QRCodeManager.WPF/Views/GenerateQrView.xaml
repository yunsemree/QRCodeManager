<UserControl x:Class="QRCodeManager.WPF.Views.GenerateQrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:QRCodeManager.WPF.Controls"
             xmlns:converters="clr-namespace:QRCodeManager.WPF.Converters">
    <UserControl.Resources>
        <converters:BoolToValidationIconBrushConverter x:Key="ValidationIconBrushConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="Eser Bilgileri"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center"
                                                 Foreground="{Binding IsFormValid, Converter={StaticResource ValidationIconBrushConverter}}" />
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Temizle"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ClearFormCommand}" />
                </StackPanel>

                <controls:AssetFormControl Urun="{Binding Urun, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Materyal="{Binding Materyal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Sahibi="{Binding Sahibi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Konumu="{Binding Konumu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           SeriNo="{Binding SeriNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           ShowRequiredHint="True" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="QR Önizleme"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}"
                           Margin="0,0,0,12" />

                <ComboBox Grid.Row="1"
                          Width="220"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,16"
                          materialDesign:HintAssist.Hint="Hata düzeltme"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding ErrorCorrectionOptions}"
                          SelectedItem="{Binding SelectedErrorCorrection}" />

                <Border Grid.Row="2"
                        Background="{DynamicResource PreviewPanelBrush}"
                        CornerRadius="12"
                        MinHeight="320"
                        Padding="20">
                    <Image Source="{Binding QrPreview}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <WrapPanel Grid.Row="3" Margin="0,16,0,0">
                    <Button Content="QR Oluştur"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding GenerateQrCommand}" />
                    <Button Content="PNG Kaydet"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding SavePngCommand}" />
                    <Button Content="Kopyala"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CopyImageCommand}" />
                </WrapPanel>

                <TextBlock Grid.Row="4"
                           Text="{Binding StatusMessage}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
