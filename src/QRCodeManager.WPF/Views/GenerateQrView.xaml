<UserControl x:Class="QRCodeManager.WPF.Views.GenerateQrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:QRCodeManager.WPF.Controls"
             xmlns:converters="clr-namespace:QRCodeManager.WPF.Converters">
    <UserControl.Resources>
        <converters:BoolToValidationIconBrushConverter x:Key="ValidationIconBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="QR İçeriği"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}" />
                    <ComboBox Margin="0,12,0,0"
                              materialDesign:HintAssist.Hint="İçerik tipi"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding ContentTypeOptions}"
                              SelectedItem="{Binding SelectedContentType}" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center"
                                                 Foreground="{Binding IsFormValid, Converter={StaticResource ValidationIconBrushConverter}}" />
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Temizle"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ClearFormCommand}" />
                </StackPanel>

                <Grid>
                    <controls:DynamicAssetFormControl Fields="{Binding Fields}"
                                                      ShowRequiredHint="True"
                                                      AddFieldCommand="{Binding AddFieldCommand}"
                                                      RemoveFieldCommand="{Binding RemoveFieldCommand}"
                                                      Visibility="{Binding IsAssetFormContent, Converter={StaticResource BoolToVisibility}}" />

                    <StackPanel Visibility="{Binding IsUrlContent, Converter={StaticResource BoolToVisibility}}">
                        <TextBox materialDesign:HintAssist.Hint="URL (https://...)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Text="{Binding UrlContent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12"
                                   Text="QR kodu doğrudan bu adrese yönlendirir." />
                    </StackPanel>

                    <TextBox Visibility="{Binding IsPlainTextContent, Converter={StaticResource BoolToVisibility}}"
                             materialDesign:HintAssist.Hint="Metin içeriği"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="160"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding PlainTextContent, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="QR Önizleme"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleTextBrush}"
                           Margin="0,0,0,12" />

                <ComboBox Grid.Row="1"
                          Width="220"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,16"
                          materialDesign:HintAssist.Hint="Hata düzeltme"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding ErrorCorrectionOptions}"
                          SelectedItem="{Binding SelectedErrorCorrection}" />

                <Border Grid.Row="2"
                        Background="{DynamicResource PreviewPanelBrush}"
                        CornerRadius="12"
                        MinHeight="320"
                        Padding="20">
                    <Image Source="{Binding QrPreview}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <WrapPanel Grid.Row="3" Margin="0,16,0,0">
                    <Button Content="QR Oluştur"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding GenerateQrCommand}" />
                    <Button Content="PNG Kaydet"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding SavePngCommand}" />
                    <Button Content="Kopyala"
                            Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CopyImageCommand}" />
                </WrapPanel>

                <TextBlock Grid.Row="4"
                           Text="{Binding StatusMessage}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
