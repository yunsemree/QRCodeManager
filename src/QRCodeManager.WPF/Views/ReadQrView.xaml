<UserControl x:Class="QRCodeManager.WPF.Views.ReadQrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="Görüntü Seç"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding OpenImageCommand}" />
            <Button Content="QR Oku"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding DecodeQrCommand}" />
            <Button Content="Bilgileri Kopyala"
                    Margin="0,0,8,8"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding CopyInfoCommand}" />
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,8"
                       Foreground="{DynamicResource MutedTextBrush}" />
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="QR Görüntüsü"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               Margin="0,0,0,16" />
                    <Border Background="{DynamicResource PreviewPanelBrush}"
                            CornerRadius="12"
                            MinHeight="380">
                        <Image Source="{Binding LoadedImage}"
                               Stretch="Uniform"
                               Margin="20" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Okunan Eser Bilgisi"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TitleTextBrush}"
                               Margin="0,0,0,16" />
                    <Border Background="{DynamicResource PreviewPanelBrush}"
                            CornerRadius="12"
                            Padding="24"
                            MinHeight="380">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding FormattedOutput}"
                                       FontFamily="Consolas"
                                       FontSize="15"
                                       LineHeight="30"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TitleTextBrush}" />
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
