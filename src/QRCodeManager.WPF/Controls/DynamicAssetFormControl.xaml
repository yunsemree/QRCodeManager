<UserControl x:Class="QRCodeManager.WPF.Controls.DynamicAssetFormControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:QRCodeManager.WPF.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding Fields, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DynamicFormField}">
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource PreviewPanelBrush}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0"
                                         materialDesign:HintAssist.Hint="Anahtar (key)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="0" Grid.Column="2"
                                         materialDesign:HintAssist.Hint="Etiket"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Grid.Row="0" Grid.Column="4"
                                          Content="Zorunlu"
                                          IsChecked="{Binding IsRequired}"
                                          VerticalAlignment="Center" />
                                <Button Grid.Row="0" Grid.Column="6"
                                        Content="Sil"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Command="{Binding RemoveFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />

                                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="7"
                                         Margin="0,12,0,0"
                                         materialDesign:HintAssist.Hint="{Binding Hint}"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Alan Ekle"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Left"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding AddFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />

            <TextBlock Margin="0,12,0,0"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       FontSize="12"
                       Text="Alan tanımları otomatik kaydedilir. * zorunlu alanlar"
                       Visibility="{Binding ShowRequiredHint, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
